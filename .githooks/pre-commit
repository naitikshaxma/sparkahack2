#!/usr/bin/env bash
set -euo pipefail

if ! command -v git >/dev/null 2>&1; then
  echo "[pre-commit] git is required." >&2
  exit 1
fi

if command -v gitleaks >/dev/null 2>&1; then
  echo "[pre-commit] Running gitleaks scan on staged changes..."
  gitleaks protect --staged --verbose
else
  echo "[pre-commit] gitleaks not found, running local regex scan..."
  if command -v python >/dev/null 2>&1; then
    python scripts/secret_scan.py
  elif command -v py >/dev/null 2>&1; then
    py -3 scripts/secret_scan.py
  else
    echo "[pre-commit] Python is required for fallback secret scan." >&2
    exit 1
  fi
fi
