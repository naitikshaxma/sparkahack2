# Backend API base URL used by frontend in production builds.
VITE_API_BASE_URL=http://localhost:8099

# Backward-compatible alias consumed by frontend API client.
VITE_BACKEND_URL=http://localhost:8099

# Dev-only proxy target for Vite (`npm run dev`).
VITE_DEV_BACKEND_URL=http://localhost:8099

# Dev-only port for Vite dev server.
VITE_DEV_PORT=5173
