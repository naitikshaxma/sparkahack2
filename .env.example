# -----------------------------
# Backend runtime configuration
# -----------------------------

# Required: OpenAI API key used by OCR and assistant flows.
# Must be a real key in local/prod environments.
OPENAI_API_KEY=replace-with-your-real-openai-key

# Optional OpenAI chat model for OCR/agent structured extraction.
OPENAI_CHAT_MODEL=gpt-4o-mini

# Whisper speech-to-text model size.
WHISPER_MODEL_SIZE=base

# Local intent model directory (HuggingFace format).
MODEL_PATH=./models/intent

# Optional remote intent model ID used if MODEL_PATH is unavailable.
HF_INTENT_MODEL_ID=

# Redis connection URL for session persistence.
REDIS_URL=redis://localhost:6379/0

# Session expiry in seconds.
SESSION_TTL_SECONDS=86400

# Maximum characters accepted for text inputs.
MAX_TEXT_INPUT_CHARS=500

# Maximum allowed session identifier length.
MAX_SESSION_ID_CHARS=64

# Rate limiting window in seconds.
API_RATE_LIMIT_WINDOW_SECONDS=60

# Max API requests per client IP inside one rate limit window.
API_RATE_LIMIT_MAX_REQUESTS=80

# Trust proxy forwarding headers (set true behind trusted reverse proxy only).
TRUST_PROXY_HEADERS=false

# If true, every /api/* request must include x-api-key or Bearer token.
ENABLE_API_KEY_AUTH=false

# Required when ENABLE_API_KEY_AUTH=true. Use a long random secret.
API_AUTH_KEY=replace-with-strong-random-token


# -----------------------------
# Frontend runtime configuration
# -----------------------------

# Backend base URL used by frontend in production builds.
VITE_BACKEND_URL=http://localhost:8000

# Preferred frontend API base URL (same as VITE_BACKEND_URL by default).
VITE_API_BASE_URL=http://localhost:8000
