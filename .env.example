# -----------------------------
# Backend runtime configuration
# -----------------------------

# Required: OpenAI API key used by OCR and assistant flows.
# Must be a real key in local/prod environments.
OPENAI_API_KEY=replace-with-your-real-openai-key

# Optional OpenAI chat model for OCR/agent structured extraction.
OPENAI_CHAT_MODEL=gpt-4o-mini

# Whisper speech-to-text model size.
WHISPER_MODEL_SIZE=base

# Local intent model directory (HuggingFace format).
MODEL_PATH=./models/intent

# Optional remote intent model ID used if MODEL_PATH is unavailable.
HF_INTENT_MODEL_ID=

# Redis connection URL for session persistence.
REDIS_URL=redis://localhost:6379/0

# Session expiry in seconds.
SESSION_TTL_SECONDS=86400

# Maximum characters accepted for text inputs.
MAX_TEXT_INPUT_CHARS=500

# Maximum allowed session identifier length.
MAX_SESSION_ID_CHARS=64

# Rate limiting window in seconds.
API_RATE_LIMIT_WINDOW_SECONDS=60

# Max API requests per client IP inside one rate limit window.
API_RATE_LIMIT_MAX_REQUESTS=80

# Max API requests per API key inside one rate limit window.
API_KEY_RATE_LIMIT_MAX_REQUESTS=120

# Max allowed request body size (bytes).
MAX_REQUEST_SIZE_BYTES=1048576

# Trust proxy forwarding headers (set true behind trusted reverse proxy only).
TRUST_PROXY_HEADERS=false

# Optional: comma-separated CORS allowlist. Leave empty for localhost defaults.
CORS_ALLOW_ORIGINS=

# If true, every /api/* request must include x-api-key or Bearer token.
ENABLE_API_KEY_AUTH=false

# Required when ENABLE_API_KEY_AUTH=true. Use a long random secret.
API_AUTH_KEY=replace-with-strong-random-token

# Optional: session store backend override (auto|redis|memory).
SESSION_STORE_BACKEND=auto

# Optional: default response tone (formal|friendly|assistant-like).
RESPONSE_TONE=assistant-like

# Optional: maximum concurrent API requests.
MAX_CONCURRENT_REQUESTS=50

# Optional: timeout (seconds) to wait for a concurrency slot.
CONCURRENCY_ACQUIRE_TIMEOUT_SECONDS=1.5

# Optional: request timeout for non-streaming endpoints (seconds).
REQUEST_TIMEOUT_SECONDS=30

# Optional: max duration for streaming endpoints (seconds).
STREAM_MAX_DURATION_SECONDS=120

# Optional: max cached voice-state entries before pruning.
MAX_VOICE_STATE_ENTRIES=2000

# Optional: max async session locks to retain before pruning.
MAX_ASYNC_LOCKS=4000

# Optional: TTS retry attempts for transient failures.
TTS_RETRY_ATTEMPTS=2

# Optional: backoff delay (ms) between TTS retry attempts.
TTS_RETRY_BACKOFF_MS=250

# Optional: throttle streaming chunk emission in ms (0 disables).
STREAM_CHUNK_DELAY_MS=0


# -----------------------------
# Frontend runtime configuration
# -----------------------------

# Backend base URL used by frontend in production builds.
VITE_BACKEND_URL=http://localhost:8099

# Preferred frontend API base URL (same as VITE_BACKEND_URL by default).
VITE_API_BASE_URL=http://localhost:8099

# Dev-only proxy target for Vite (`npm run dev`).
VITE_DEV_BACKEND_URL=http://localhost:8099

# Dev-only port for Vite dev server.
VITE_DEV_PORT=5173
