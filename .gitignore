# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.so

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
dist/
build/
.cache/
*.tsbuildinfo
frontend/.env
!frontend/.env.example
!frontend/.env.production

# ── IDE & tooling ─────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── VS Code (keep project-level settings, ignore personal) ───────────────────
.vscode/

# ── Type checkers ─────────────────────────────────────────────────────────────
.mypy_cache/
.pyre/
.pyright/

# ── Test & coverage ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ── Logs & temp ───────────────────────────────────────────────────────────────
*.log
*.log.*
logs/
tmp/
temp/

# ── Binary tools (never commit executables) ──────────────────────────────────
tools/*.exe
tools/*.bin

# ── Generated snapshot files ──────────────────────────────────────────────────
tree_output*.txt

# ── Project generated artifacts ───────────────────────────────────────────────
backend/data/processed/*.json
frontend/dist/
frontend/.fallback/
intent_stability_*.json
validation_report.json
intent_full_validation_report.json

# ── Datasets (large — use DVC or object storage) ─────────────────────────────
datasets/

# ── ML models (use model registry) ───────────────────────────────────────────
*.pt
*.bin
*.safetensors
models/

# ── Docker overrides ──────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Railway deployment context slimming ───────────────────────────────────────
*.db
*.csv
data/
tools/
scripts/
frontend/
**/__pycache__/
